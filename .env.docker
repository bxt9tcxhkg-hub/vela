# Vela Docker – Konfiguration
# Kopiere diese Datei nach .env und passe sie an

VELA_NAME=Vela

# Mindestens einen Provider konfigurieren:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Ollama auf dem Host (Standard – kein Key nötig)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# Gmail (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
