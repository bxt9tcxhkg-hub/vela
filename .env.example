# Vela – Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle die Werte aus

# Server
PORT=3000
HOST=127.0.0.1
NODE_ENV=production
JWT_SECRET=change-me-in-production

# Betriebsmodus: local (Ollama) oder cloud
DEFAULT_MODE=local

# Cloud-Provider Keys (mind. einen setzen für Cloud-Modus)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Standard-Modell (Cloud)
DEFAULT_MODEL=claude-haiku-4-5-20251001

# Ollama (Lokal-Modus)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OIDC / SSO (optional)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# Email Inbound Trigger (optional)
EMAIL_TRIGGER_HOST=
EMAIL_TRIGGER_USER=
EMAIL_TRIGGER_PASS=
EMAIL_TRIGGER_PORT=993
EMAIL_TRIGGER_TLS=true
