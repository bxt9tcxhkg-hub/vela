{
  "name": "vela",
  "version": "0.1.0",
  "private": true,
  "description": "Personal AI agent platform – secure, accessible, self-hosted",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "server": "turbo run dev --filter=@vela/server"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.8"
    },
    "neverBuiltDependencies": [
      "i18next",
      "react-i18next",
      "i18next-browser-languagedetector"
    ]
  },
  "dependencies": {
    "node-cron": "^4.2.1"
  }
}