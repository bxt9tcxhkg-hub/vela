{
  "name": "@vela/desktop",
  "version": "0.1.0",
  "description": "Vela desktop app \u2013 Electron shell",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm run electron:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.json",
    "electron:dev": "tsc -p tsconfig.json --watch",
    "pack": "electron-builder --dir",
    "dist:win": "tsc -p tsconfig.json && electron-builder --win",
    "dist:mac": "tsc -p tsconfig.json && electron-builder --mac",
    "dist:linux": "tsc -p tsconfig.json && electron-builder --linux",
    "clean": "rm -rf dist out",
    "dist:all": "tsc -p tsconfig.json && electron-builder --win --mac --linux",
    "release": "pnpm run dist:all --publish=always"
  },
  "dependencies": {
    "@vela/core": "file:../core",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ai.vela.app",
    "productName": "Vela",
    "copyright": "Copyright \u00a9 2026 Vela Contributors",
    "asar": true,
    "directories": {
      "output": "release/${version}",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "node_modules/**/*",
      "!node_modules/**/README*",
      "!node_modules/**/*.md"
    ],
    "extraResources": [
      {
        "from": "../ui/dist",
        "to": "ui/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../server/dist",
        "to": "server/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vela"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "bxt9tcxhkg-hub",
      "repo": "vela",
      "releaseType": "release"
    }
  },
  "author": {
    "name": "Vela Contributors",
    "email": "dev@vela.ai"
  },
  "homepage": "https://github.com/bxt9tcxhkg-hub/vela"
}