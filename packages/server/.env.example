# ─── KI-Backends ─────────────────────────────────────────────────────────────
# Mindestens einen Key setzen. Groq und Gemini sind kostenlos.

# Google Gemini (kostenlos, kein Credit Card) → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (kostenlos, sehr schnell) → https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude (kostenpflichtig) → https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (kostenpflichtig) → https://platform.openai.com
OPENAI_API_KEY=

# ─── Backend-Auswahl ─────────────────────────────────────────────────────────
# Optionen: gemini | groq | anthropic | local | openai
# "local" = Ollama (vollständig offline)
VELA_BACKEND=gemini

# Standard-Modell (optional, Backend wählt automatisch wenn leer)
DEFAULT_MODEL=

# OpenAI-kompatibler Endpunkt (Experten: LM Studio, OpenRouter, llama.cpp, etc.)
VELA_OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Nutzer-Präferenzen (vom Onboarding gesetzt) ────────────────────────────
VELA_PREF_LEVEL=laie
VELA_PREF_LANGUAGE=Deutsch
VELA_PREF_TONE=einfach
VELA_PREF_PURPOSE=alltag
VELA_PREF_NAME=

# ─── Messenger (optional) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# ─── Gmail OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── Persönlichkeit (optional) ───────────────────────────────────────────────
VELA_NAME=Vela
VELA_SYSTEM_PROMPT=

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# WICHTIG: 127.0.0.1 = nur lokal erreichbar (Sicherheit!)
# Niemals 0.0.0.0 setzen außer du weißt was du tust.
HOST=127.0.0.1
