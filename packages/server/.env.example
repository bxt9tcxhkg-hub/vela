# ── Vela Server – Konfiguration ───────────────────────────────────────────────
# Kopiere diese Datei nach .env und fülle die benötigten Werte aus.

# Server
PORT=3000
NODE_ENV=development

# Vela Persönlichkeit
VELA_NAME=Vela
VELA_SYSTEM_PROMPT=Du bist Vela, ein persönlicher KI-Assistent. Hilfsbereit, präzise, auf Deutsch.

# ── AI Provider ───────────────────────────────────────────────────────────────
# Nur einen Provider konfigurieren – oder mehrere für Moduswechsel

# Ollama (Standard – läuft lokal, kein API-Key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=claude-haiku-4-5-20251001

# OpenAI GPT-4o
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AIza...

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Für email-reader und email-sender Skills
# Setup: https://console.cloud.google.com → APIs → Gmail API aktivieren
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
